# DermAI by Skana — Environment Variables Template

# Primary API key for AI description generation (Google AI Studio — Gemini)
GEMINI_PRIMARY_API_KEY=

# Backup API key for AI description generation — used as automatic fallback
# when the primary key hits a 429 rate limit error
GEMINI_BACKUP_API_KEY=

# API key for the DermAI chatbot (Google AI Studio — Gemma)
GEMMA_API_KEY=
